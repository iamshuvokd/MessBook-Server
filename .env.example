PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=devroot
DB_NAME=mess_manager

# Socket.IO Redis adapter (live chat + live data-update broadcasts across API
# instances). Optional -- unset falls back to Socket.IO's single-process
# adapter, fine for one instance. Docker Compose supplies its own value
# (redis://redis:6379); only needed here for `npm run dev` outside Docker.
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated Android + Web OAuth client IDs from Google Cloud Console (Step 4).
GOOGLE_CLIENT_IDS=

# Comma-separated Gmail addresses that get Master Admin dashboard access.
MASTER_ADMIN_EMAILS=

# Path to the Firebase service account key (Project Settings -> Service
# accounts -> Generate new private key) used to send chat push notifications.
# Optional -- if missing, push is silently skipped and chat still works over
# the socket. Defaults to ./secrets/firebase-service-account.json.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
